<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  drivers/macos/Info.plist
  Bundle descriptor for the Virtuoso AudioServerPlugIn HAL driver.
  Install path: /Library/Audio/Plug-Ins/HAL/VirtuosoAudioPlugin.driver/Contents/
-->
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>audio.virtuoso.app.haldriver</string>

    <key>CFBundleName</key>
    <string>VirtuosoAudioPlugin</string>

    <key>CFBundleDisplayName</key>
    <string>Virtuoso Audio HAL Plugin</string>

    <key>CFBundleVersion</key>
    <string>1.0.0</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <key>CFBundlePackageType</key>
    <string>BNDL</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <!-- AudioServerPlugIn factory UUID — must match the UUID returned by VirtuosoPlugIn_Create -->
    <key>AudioServerPlugIn_FactoryUUIDs</key>
    <array>
        <string>DEADBEEF-1234-5678-ABCD-EF0123456789</string>
    </array>

    <!-- Entry point exported by the .dylib -->
    <key>CFPlugInFactories</key>
    <dict>
        <key>DEADBEEF-1234-5678-ABCD-EF0123456789</key>
        <string>VirtuosoPlugIn_Create</string>
    </dict>

    <key>CFPlugInTypes</key>
    <dict>
        <!-- kAudioServerPlugInTypeUUID -->
        <key>443ABAB8-E7B3-491A-B985-BEB9187030DB</key>
        <array>
            <string>DEADBEEF-1234-5678-ABCD-EF0123456789</string>
        </array>
    </dict>

    <!-- Minimum macOS supported -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Virtuoso Audio Project Contributors. MIT License.</string>
</dict>
</plist>
